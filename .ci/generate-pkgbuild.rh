#!/usr/bin/env rash

- assert:
    that:
      - "env.PROJECT_NAME is defined"
      - "env.PROJECT_VERSION is defined"
      - "env.PROJECT_DESCRIPTION is defined"
      - "env.PROJECT_HOMEPAGE is defined"

- name: Create PKGBUILD
  template:
    src: "{{ rash.dir }}/{{ item }}.j2"
    dest: "{{ item }}"
  loop:
    - PKGBUILD
    - PKGBUILD-bin
