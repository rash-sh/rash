#!/bin/bash
# Snap binary mock for Snap module tests.
#
# Usage:
#   ./snap.rh [options] (list|install|remove) [<packages>]...

while [[ $# -gt 0 ]]; do
    case $1 in
        list)
            echo "Name                       Version           Rev    Tracking         Publisher   Notes"
            echo "core18                     20231219          2812   latest/stable    canonical**  base"
            echo "code                       1.85.1            152    latest/stable    msasci✓     classic"
            echo "slack                      4.38.121          119    latest/stable    slack✓      -"
            exit 0
            ;;
        install)
            shift
            while [[ $# -gt 0 ]]; do
                case $1 in
                    --*)
                        shift
                        ;;
                    *)
                        echo "$1 installed"
                        shift
                        ;;
                esac
            done
            exit 0
            ;;
        remove)
            shift
            while [[ $# -gt 0 ]]; do
                case $1 in
                    --*)
                        shift
                        ;;
                    *)
                        echo "$1 removed"
                        shift
                        ;;
                esac
            done
            exit 0
            ;;
        --classic|--channel=*|--verbose)
            shift
            ;;
        *)
            shift
            ;;
    esac
done
